{
  "locale_code": "tr",
  "locale_name": "Turkish",
  "language_detection": {
    "sample_terms": ["sigorta", "poliçe", "teminat", "prim", "ve", "için", "ile", "sigortacı", "sigortalı"],
    "min_matches_for_detection": 3,
    "character_sets": ["latin", "turkish_special"],
    "special_characters": ["ğ", "ü", "ş", "ı", "ö", "ç", "İ", "Ğ", "Ü", "Ş", "Ö", "Ç"]
  },
  "encoding_validation": {
    "expected_characters": "a-zA-ZğüşıöçĞÜŞİÖÇ0-9",
    "garbage_patterns": [
      "[ï¿½]{2,}",
      "[�]{2,}",
      "Ä±",
      "Ã¼",
      "ÅŸ",
      "Ä°",
      "Ã§",
      "Ã¶",
      "Ã¼"
    ]
  },
  "insurance_terminology": {
    "core_terms": [
      "sigorta",
      "poliçe",
      "teminat",
      "prim",
      "sigortalı",
      "muafiyet",
      "hasar",
      "tazminat",
      "riziko",
      "acente",
      "lehdar",
      "sigorta ettiren",
      "sigortacı",
      "police",
      "tanzim",
      "vade"
    ],
    "document_structure_terms": [
      "madde",
      "kloz",
      "şartlar",
      "kapsam",
      "limit",
      "ek sözleşme",
      "genel şartlar",
      "özel şartlar",
      "teminat tablosu",
      "prim hesabı"
    ],
    "common_values": [
      "TL",
      "tarih",
      "no",
      "numara",
      "adres",
      "telefon",
      "vade",
      "başlangıç",
      "bitiş",
      "toplam"
    ]
  },
  "date_formats": [
    "DD/MM/YYYY",
    "DD.MM.YYYY",
    "DD-MM-YYYY",
    "YYYY-MM-DD"
  ],
  "date_patterns": [
    "\\d{2}[./\\-]\\d{2}[./\\-]\\d{4}",
    "\\d{4}[./\\-]\\d{2}[./\\-]\\d{2}"
  ],
  "currency": {
    "code": "TRY",
    "symbol": "₺",
    "patterns": [
      "([\\d.,]+)\\s*TL",
      "([\\d.,]+)\\s*₺",
      "TL\\s*([\\d.,]+)",
      "₺\\s*([\\d.,]+)"
    ],
    "decimal_separator": ",",
    "thousands_separator": "."
  },
  "number_formats": {
    "decimal_separator": ",",
    "thousands_separator": ".",
    "patterns": [
      "([\\d.]+,\\d{2})",
      "([\\d,]+\\.\\d{2})"
    ]
  },
  "identifiers": {
    "tc_kimlik": {
      "name": "TC Kimlik No",
      "pattern": "\\b[1-9]\\d{10}\\b",
      "description": "Turkish national ID number"
    },
    "vergi_no": {
      "name": "Vergi No",
      "pattern": "\\b\\d{10}\\b",
      "description": "Turkish tax number"
    },
    "iban": {
      "name": "IBAN",
      "pattern": "TR\\d{2}\\s*\\d{4}\\s*\\d{4}\\s*\\d{4}\\s*\\d{4}\\s*\\d{4}\\s*\\d{2}",
      "description": "Turkish IBAN"
    },
    "phone": {
      "name": "Telefon",
      "pattern": "(?:\\+90|0)?\\s*(?:\\d{3}\\s*\\d{3}\\s*\\d{2}\\s*\\d{2}|\\(\\d{3}\\)\\s*\\d{3}\\s*\\d{2}\\s*\\d{2})",
      "description": "Turkish phone number"
    },
    "plate": {
      "name": "Plaka",
      "pattern": "\\d{2}\\s*[A-ZİĞÜŞÖÇ]{1,3}\\s*\\d{2,5}",
      "description": "Turkish vehicle plate"
    }
  }
}
