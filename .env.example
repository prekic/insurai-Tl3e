# InsurAI Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# API PROXY (Recommended for production - keeps API keys secure)
# =============================================================================

# Backend API proxy URL
# When set, frontend uses the secure backend proxy instead of direct API calls
# This keeps your API keys on the server, never exposed to the browser
#
# Development: http://localhost:3001
# Production:  https://api.your-domain.com
VITE_API_PROXY_URL=

# =============================================================================
# SUPABASE (Optional - for cloud storage and authentication)
# =============================================================================
# Get these from your Supabase project settings: https://supabase.com/dashboard
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# =============================================================================
# AI PROVIDERS - DEVELOPMENT ONLY
# =============================================================================
# WARNING: These keys are exposed in the browser!
# Only use these for local development. In production, use the backend proxy.

# OpenAI (Primary AI provider for document extraction)
# Get your API key: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk-proj-...

# Anthropic/Claude (Backup AI for multi-model consensus)
# Get your API key: https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_API_KEY=sk-ant-...

# Google Cloud Vision API (for OCR of scanned PDFs)
# Enable Vision API and create credentials: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLOUD_API_KEY=AIza...

# =============================================================================
# APP CONFIGURATION (Optional)
# =============================================================================

# App URL (used for OAuth redirects)
VITE_APP_URL=http://localhost:5173

# =============================================================================
# BACKEND SERVER CONFIGURATION
# =============================================================================
# These are used by the Express backend server (server/index.ts)

# Server port
API_PORT=3001

# Frontend URL (for CORS - must match your frontend origin)
FRONTEND_URL=http://localhost:5173

# AI Provider API Keys (server-side - secure, never exposed to browser)
OPENAI_API_KEY=sk-proj-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
GOOGLE_CLOUD_API_KEY=AIza-your-key-here

# Environment mode
NODE_ENV=development
