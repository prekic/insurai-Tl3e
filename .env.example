# InsurAI Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

# Supabase (for authentication and cloud storage)
# Get these from your Supabase project: https://supabase.com/dashboard
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend API Proxy URL
# Routes AI calls through secure server - keeps API keys off the browser
# Development: http://localhost:3001
# Production:  https://api.your-domain.com
VITE_API_PROXY_URL=http://localhost:3001

# App URL (for OAuth redirects)
VITE_APP_URL=http://localhost:5173

# =============================================================================
# BACKEND SERVER CONFIGURATION (server/index.ts)
# =============================================================================

# Server port
API_PORT=3001

# Frontend URL for CORS (must match your frontend origin)
FRONTEND_URL=http://localhost:5173

# Environment mode
NODE_ENV=development

# =============================================================================
# RATE LIMITING (Optional - defaults shown)
# =============================================================================
# Configure request limits to prevent abuse and control API costs.

# General API rate limit (requests per window)
# RATE_LIMIT_WINDOW_MS=900000    # 15 minutes (default)
# RATE_LIMIT_MAX=100             # 100 requests per window (default)

# AI extraction rate limit (expensive operations)
# RATE_LIMIT_AI_WINDOW_MS=3600000  # 1 hour (default)
# RATE_LIMIT_AI_MAX=20             # 20 requests per hour (default)

# OCR rate limit
# RATE_LIMIT_OCR_WINDOW_MS=3600000  # 1 hour (default)
# RATE_LIMIT_OCR_MAX=30             # 30 requests per hour (default)

# =============================================================================
# AI PROVIDER API KEYS (Server-side only - secure)
# =============================================================================
# These keys stay on the server and are NEVER exposed to the browser.
# The frontend uses VITE_API_PROXY_URL to route requests through the server.

# OpenAI (Primary AI for document extraction)
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-key-here

# Anthropic/Claude (Backup AI for multi-model consensus)
# Get your key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google Cloud Vision (OCR for scanned PDFs)
# Enable Vision API: https://console.cloud.google.com/apis/credentials
GOOGLE_CLOUD_API_KEY=AIza-your-key-here

# =============================================================================
# ERROR TRACKING (Sentry)
# =============================================================================
# Production error monitoring and performance tracking.
# Create a project at: https://sentry.io

# Sentry DSN (Data Source Name) - enables error tracking
# Get this from: Sentry Project Settings > Client Keys (DSN)
VITE_SENTRY_DSN=https://your-key@sentry.io/your-project-id

# App version for release tracking (optional)
VITE_APP_VERSION=0.1.0

# Enable Sentry in development for testing (optional)
# VITE_SENTRY_DEBUG=true

# Source map upload configuration (CI/CD only)
# These are only needed for uploading source maps during builds
# SENTRY_AUTH_TOKEN=your-auth-token
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
