# InsurAI Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

# Supabase (for authentication and cloud storage)
# Get these from your Supabase project: https://supabase.com/dashboard
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend API Proxy URL
# Routes AI calls through secure server - keeps API keys off the browser
# Development: http://localhost:4001
# Production:  https://api.your-domain.com
VITE_API_PROXY_URL=http://localhost:4001

# App URL (for OAuth redirects)
VITE_APP_URL=http://localhost:5173

# =============================================================================
# BACKEND SERVER CONFIGURATION (server/index.ts)
# =============================================================================

# Server port
API_PORT=4001

# Frontend URL for CORS (must match your frontend origin)
FRONTEND_URL=http://localhost:5173

# Environment mode
NODE_ENV=development

# =============================================================================
# SUPABASE SERVER-SIDE (Required for admin auth)
# =============================================================================
# IMPORTANT: These are SERVER-SIDE ONLY variables - do NOT prefix with VITE_
# Get these from Supabase Dashboard > Settings > API

# Supabase URL (same as VITE_SUPABASE_URL but for server-side)
SUPABASE_URL=https://your-project.supabase.co

# Service Role Key - KEEP SECRET! This bypasses RLS
# Get from: Supabase Dashboard > Settings > API > Service Role Key
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...your-service-role-key

# =============================================================================
# ADMIN AUTHENTICATION (Optional - defaults shown)
# =============================================================================
# JWT settings for admin authentication

# Admin JWT secret key - CHANGE IN PRODUCTION!
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ADMIN_JWT_SECRET=change-this-to-a-random-string-in-production

# Token expiration times
# ADMIN_JWT_EXPIRES_IN=30m
# ADMIN_REFRESH_EXPIRES_IN=7d

# Admin Email → UUID Resolver (OPT-IN, privacy-sensitive)
# When true, /api/admin/app-users/resolve-emails exposes auth.users.email to
# super-admins. Used by the Segments admin tab's "Paste Emails" mode.
# Default: disabled. Enable only after a privacy review.
# ENABLE_ADMIN_EMAIL_RESOLVER=true

# =============================================================================
# RATE LIMITING (Optional - defaults shown)
# =============================================================================
# Configure request limits to prevent abuse and control API costs.

# General API rate limit (requests per window)
# RATE_LIMIT_WINDOW_MS=900000    # 15 minutes (default)
# RATE_LIMIT_MAX=100             # 100 requests per window (default)

# AI extraction rate limit (expensive operations)
# RATE_LIMIT_AI_WINDOW_MS=3600000  # 1 hour (default)
# RATE_LIMIT_AI_MAX=20             # 20 requests per hour (default)

# OCR rate limit
# RATE_LIMIT_OCR_WINDOW_MS=3600000  # 1 hour (default)
# RATE_LIMIT_OCR_MAX=30             # 30 requests per hour (default)

# =============================================================================
# AI PROVIDER API KEYS (Server-side only - secure)
# =============================================================================
# These keys stay on the server and are NEVER exposed to the browser.
# The frontend uses VITE_API_PROXY_URL to route requests through the server.

# OpenAI (Primary AI for document extraction)
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-key-here

# Anthropic/Claude (Backup AI for multi-model consensus)
# Get your key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google Cloud Vision (OCR for scanned PDFs)
# Enable Vision API: https://console.cloud.google.com/apis/credentials
GOOGLE_CLOUD_API_KEY=AIza-your-key-here

# =============================================================================
# ENTERPRISE OCR ENGINES (For multi-engine OCR orchestration)
# =============================================================================
# These are used by the OCR orchestrator microservice for enterprise-grade
# document processing with consensus voting across multiple engines.

# OCR Orchestrator Service URL (enables multi-engine OCR)
# If set, the app will use the orchestrator for ensemble OCR
# VITE_OCR_ORCHESTRATOR_URL=http://localhost:4006

# ABBYY Cloud OCR (High-accuracy printed text, Turkish support)
# Sign up: https://cloud.ocrsdk.com/
# ABBYY_API_URL=https://cloud-westus.ocrsdk.com
# ABBYY_APP_ID=your-app-id
# ABBYY_PASSWORD=your-password

# Google Cloud Document AI (Form understanding, table extraction)
# Enable API: https://console.cloud.google.com/apis/library/documentai.googleapis.com
# Create processor: https://console.cloud.google.com/ai/document-ai/processors
GCP_PROJECT_ID=gen-lang-client-0171803889
GCP_LOCATION=us
GCP_DOCAI_PROCESSOR_ID=c2741b178ab61433
# Credentials — provide ONE of the following three (script tries base64 → file path → default):
#   1. Base64-encoded service account JSON (sandbox-friendly, used by scripts/pilot-batch-ingest.ts OCR fallback)
# GCP_SERVICE_ACCOUNT_BASE64=<base64 of gcp-service-account.json>
#   2. File path to service account JSON
# GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json
#   3. Default fallback: ./gcp-service-account.json at the project root

# Azure Document Intelligence (Complex layouts, handwriting)
# Create resource: https://portal.azure.com/#create/Microsoft.CognitiveServicesFormRecognizer
# AZURE_DI_ENDPOINT=https://your-resource.cognitiveservices.azure.com
# AZURE_DI_API_KEY=your-api-key

# Tesseract OCR (Local fallback - no credentials needed)
# Install: apt-get install tesseract-ocr tesseract-ocr-tur

# =============================================================================
# PUSH NOTIFICATIONS (Web Push / VAPID)
# =============================================================================
# Required for browser push notifications (extraction complete, policy expiry alerts).
# Generate a VAPID key pair ONE TIME per deployment:
#   node -e "const wp=require('web-push'); console.log(JSON.stringify(wp.generateVAPIDKeys(),null,2))"
# Copy the generated publicKey → VAPID_PUBLIC_KEY, privateKey → VAPID_PRIVATE_KEY.
# NEVER regenerate these keys in production — existing browser subscriptions will break.

# VAPID public key (sent to browser when subscribing — safe to expose)
VAPID_PUBLIC_KEY=your-vapid-public-key-here

# VAPID private key (server-side only — NEVER expose to browser)
VAPID_PRIVATE_KEY=your-vapid-private-key-here

# VAPID subject (contact URL or mailto for push service identification)
VAPID_SUBJECT=mailto:contact@insurai.com

# =============================================================================
# ERROR TRACKING (Sentry)
# =============================================================================
# Production error monitoring and performance tracking.
# Create a project at: https://sentry.io

# Sentry DSN (Data Source Name) - enables error tracking
# Get this from: Sentry Project Settings > Client Keys (DSN)
VITE_SENTRY_DSN=https://your-key@sentry.io/your-project-id

# App version for release tracking (optional)
VITE_APP_VERSION=0.1.0

# Enable Sentry in development for testing (optional)
# VITE_SENTRY_DEBUG=true

# Source map upload configuration (CI/CD only)
# These are only needed for uploading source maps during builds
# SENTRY_AUTH_TOKEN=your-auth-token
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project

# ============================================
# Pilot batch ingestion (scripts/pilot-batch-ingest.ts)
# ============================================
# Valid auth.users UUID used as policies.user_id when running with
# --persist-policies flag. MUST exist in auth.users or insert fails
# the FK constraint. Can also be passed via --reviewer-id=<uuid> on
# the command line, which takes precedence over this env var.
# See docs/runbooks/03-pilot-batch-ingestion.md §1.2 for 3 ways to
# source a valid UUID (Supabase Studio, SQL query, or CLI).
# PILOT_REVIEWER_USER_ID=12345678-1234-1234-1234-123456789abc
