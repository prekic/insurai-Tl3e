# InsurAI Staging Environment Variables
# This file contains staging-specific configuration.
# Actual secrets should be set in CI/CD environment variables.

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

# Supabase Staging Project
# Create a separate Supabase project for staging
VITE_SUPABASE_URL=https://your-staging-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-staging-anon-key

# Backend API Proxy URL (staging server)
VITE_API_PROXY_URL=https://api-staging.insurai.app

# App URL (staging frontend)
VITE_APP_URL=https://staging.insurai.app

# =============================================================================
# BACKEND SERVER CONFIGURATION
# =============================================================================

# Server port (use default in container/cloud)
API_PORT=3001

# Frontend URL for CORS (staging)
FRONTEND_URL=https://staging.insurai.app

# Environment mode
NODE_ENV=staging

# =============================================================================
# ERROR TRACKING (Sentry)
# =============================================================================

# Frontend Sentry - use staging project or shared with dev environment
VITE_SENTRY_DSN=https://your-key@sentry.io/your-staging-project
VITE_SENTRY_ENVIRONMENT=staging

# Backend Sentry (same DSN or separate project)
SENTRY_DSN=https://your-key@sentry.io/your-staging-project
SENTRY_ENVIRONMENT=staging

# Source map upload (set in CI/CD secrets, not here)
# SENTRY_AUTH_TOKEN=sntrys_xxx
# SENTRY_ORG=your-org
# SENTRY_PROJECT=insurai-web

# App version (updated by CI/CD)
VITE_APP_VERSION=${npm_package_version}
APP_VERSION=${npm_package_version}

# =============================================================================
# AI PROVIDER API KEYS
# =============================================================================
# These should be set as secrets in your CI/CD platform (GitHub, Vercel, etc.)
# Using staging-specific API keys with lower rate limits is recommended.

# OPENAI_API_KEY=sk-proj-staging-key
# ANTHROPIC_API_KEY=sk-ant-staging-key
# GOOGLE_CLOUD_API_KEY=AIza-staging-key

# =============================================================================
# RATE LIMITING (Staging - more restrictive)
# =============================================================================

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=50

RATE_LIMIT_AI_WINDOW_MS=3600000
RATE_LIMIT_AI_MAX=10

RATE_LIMIT_OCR_WINDOW_MS=3600000
RATE_LIMIT_OCR_MAX=15

# =============================================================================
# FEATURE FLAGS (Staging)
# =============================================================================

# Enable debug features for testing
VITE_DEBUG_MODE=true

# Enable all features for testing
VITE_FEATURE_AI_EXTRACTION=true
VITE_FEATURE_OCR=true
VITE_FEATURE_MULTI_PROVIDER=true
