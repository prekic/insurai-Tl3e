{
  "name": "insurai",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "dev:sync": "git pull origin claude/build-app-from-design-GBWjx && npm install && npm run dev:all",
    "build": "(rm -rf node_modules/.cache node_modules/.vite 2>/dev/null || true) && tsc -b && vite build",
    "build:analyze": "ANALYZE=true tsc -b && vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "start:server": "node dist-server/server/index.js",
    "start:prod": "npm run build && npm run build:server && NODE_ENV=production node dist-server/server/index.js",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 85",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:open": "vitest run --coverage && open coverage/index.html",
    "validate": "npm run typecheck && npm run lint && npm run test",
    "loadtest": "tsx scripts/load-test.ts",
    "loadtest:quick": "LOAD_TEST_DURATION=5 tsx scripts/load-test.ts",
    "loadtest:stress": "LOAD_TEST_DURATION=30 LOAD_TEST_CONNECTIONS=100 tsx scripts/load-test.ts",
    "qa:extraction": "tsx scripts/qa-extraction-quality.ts",
    "smoke:kasko": "tsx scripts/smoke-kasko.ts",
    "audit:judge": "tsx scripts/audit-judge-corpus.ts",
    "audit:trends": "tsx scripts/audit-trend-track.ts",
    "diagnose:audit": "tsx scripts/diagnose-audit-judge-observability.ts",
    "test:e2e": "playwright test",
    "test:e2e:fast": "playwright test --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "lighthouse": "lhci autorun",
    "lighthouse:collect": "lhci collect",
    "lighthouse:assert": "lhci assert",
    "lighthouse:upload": "lhci upload",
    "prepare": "husky",
    "postinstall": "node scripts/copy-pdfjs-worker.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@google/genai": "^1.50.1",
    "@google/generative-ai": "^0.24.1",
    "@radix-ui/react-accordion": "^1.2.2",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@sentry/node": "^10.32.1",
    "@sentry/react": "^10.32.1",
    "@sentry/vite-plugin": "^4.6.1",
    "@supabase/supabase-js": "^2.98.0",
    "@types/compression": "^1.8.1",
    "@types/multer": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dommatrix": "^0.1.1",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "framer-motion": "^11.15.0",
    "google-auth-library": "^10.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.563.0",
    "multer": "^2.0.2",
    "openai": "^6.18.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.4.530",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "recharts": "^2.15.4",
    "sonner": "^1.7.1",
    "tailwind-merge": "^3.4.0",
    "web-push": "^3.6.7",
    "web-vitals": "^5.1.0",
    "ws": "^8.20.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/autocannon": "^7.12.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.3",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^5.1.3",
    "@vitest/coverage-v8": "^4.0.18",
    "autocannon": "^8.0.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.4.49",
    "prettier": "^3.7.4",
    "rollup-plugin-visualizer": "^6.0.5",
    "serve": "^14.2.5",
    "supertest": "^7.1.4",
    "tailwindcss": "^4.0.0",
    "ts-morph": "^28.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "esbuild": ">=0.25.0",
    "tmp": ">=0.2.4"
  }
}
