# InsurAI Production Environment Variables
# This file is a TEMPLATE - actual secrets should be set via CI/CD environment
# NEVER commit real API keys to version control!

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

# Supabase Production Project
# Create a separate Supabase project for production
VITE_SUPABASE_URL=https://your-production-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-production-anon-key

# Backend API Proxy URL (your production API server)
VITE_API_PROXY_URL=https://api.insurai.app

# App URL (production frontend domain)
VITE_APP_URL=https://insurai.app

# =============================================================================
# BACKEND SERVER CONFIGURATION
# =============================================================================

# Server port (typically 4001, but may be set by hosting platform)
API_PORT=4001

# Frontend URL for CORS (must match production frontend)
FRONTEND_URL=https://insurai.app

# Environment mode
NODE_ENV=production

# =============================================================================
# RATE LIMITING (Production - stricter limits)
# =============================================================================

# General API rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# AI extraction rate limit (expensive operations)
RATE_LIMIT_AI_WINDOW_MS=3600000
RATE_LIMIT_AI_MAX=20

# Chat rate limit
RATE_LIMIT_CHAT_WINDOW_MS=3600000
RATE_LIMIT_CHAT_MAX=60

# OCR rate limit
RATE_LIMIT_OCR_WINDOW_MS=3600000
RATE_LIMIT_OCR_MAX=30

# =============================================================================
# AI PROVIDER API KEYS
# =============================================================================
# IMPORTANT: Set these as secrets in your CI/CD platform (Vercel, Railway, etc.)
# DO NOT put real keys in this file!

# OpenAI - Primary AI provider
# OPENAI_API_KEY=sk-proj-xxx (SET IN CI/CD)

# Anthropic - Secondary AI provider
# ANTHROPIC_API_KEY=sk-ant-xxx (SET IN CI/CD)

# Google Cloud Vision - OCR for scanned PDFs
# GOOGLE_CLOUD_API_KEY=AIza-xxx (SET IN CI/CD)

# =============================================================================
# ERROR TRACKING (Sentry)
# =============================================================================

# Production Sentry DSN
VITE_SENTRY_DSN=https://your-key@sentry.io/your-production-project

# Environment identifier
VITE_SENTRY_ENVIRONMENT=production

# App version (updated by CI/CD from package.json)
VITE_APP_VERSION=${npm_package_version}
APP_VERSION=${npm_package_version}

# Source maps (set in CI/CD for upload during build)
# SENTRY_AUTH_TOKEN=sntrys_xxx
# SENTRY_ORG=your-org
# SENTRY_PROJECT=insurai-web

# =============================================================================
# FEATURE FLAGS (Production)
# =============================================================================

# Enable production features
VITE_FEATURE_AI_EXTRACTION=true
VITE_FEATURE_OCR=true
VITE_FEATURE_MULTI_PROVIDER=true

# Disable debug mode in production
VITE_DEBUG_MODE=false

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

# Cookie settings (if using cookies for sessions)
COOKIE_SECURE=true
COOKIE_SAME_SITE=strict

# Request body limits
MAX_REQUEST_SIZE=10mb

# Request timeout (ms)
REQUEST_TIMEOUT=30000
